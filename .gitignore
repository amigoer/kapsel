# Xcode
#
# Reference: https://github.com/github/gitignore/blob/main/Swift.gitignore

# Build artifacts
build/
Build/
DerivedData/
*.dSYM/
*.dSYM.zip
*.ipa
*.xcarchive
*.hmap
*.linkFileList

# User settings
xcuserdata/
**/xcuserdata/
*.xcuserstate
*.xcuserdatad
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcworkspace
!default.xcworkspace
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.moved-aside
*.xccheckout
*.xcscmblueprint

# Xcode test & coverage
*.xcresult
*.profraw
*.profdata
coverage/

# Carthage
Carthage/Build/

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.pins

# CocoaPods
Pods/

# macOS Finder files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Editors & local tooling
.idea/
.vscode/
*.swp
*~
.cursor/
.agents/

# Logs & temp files
*.log
*.tmp
*.temp
*.orig
*.rej

# Local configuration & secrets
.env
.env.local
.env.*.local
*.pem
*.p12
credentials.json
secrets.json
